{
  "name": "strat",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -k -n server,client -c blue,green \"npm run server\" \"npm run client\"",
    "server": "node --watch server/index.js",
    "client": "vite",
    "build": "vite build",
    "start": "node server/index.js"
  },
  "dependencies": {
    "colyseus": "^0.15.16",
    "colyseus.js": "^0.15.16",
    "express": "^4.19.2",
    "three": "^0.160.0",
    "vite": "^5.4.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
